# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Canonical site URL for metadata / Open Graph (no trailing slash). Use your BuckParts domain in production.
NEXT_PUBLIC_SITE_URL=https://your-buckparts-domain.example

# Optional: override the public product name in the header and default metadata (default: BuckParts)
# NEXT_PUBLIC_SITE_NAME=BuckParts

# Server-only: CSV import scripts (scripts/import-seed.ts). Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
